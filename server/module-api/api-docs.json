          },
          "performedBy": {
            "$ref": "#/components/schemas/AccountDto"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "statusFrom": {
            "type": "string",
            "enum": [
              "OPEN",
              "IN_PROGRESS",
              "DONE"
            ]
          },
          "statusTo": {
            "type": "string",
            "enum": [
              "OPEN",
              "IN_PROGRESS",
              "DONE"
            ]
          },
          "commentText": {
            "type": "string"
          }
        }
